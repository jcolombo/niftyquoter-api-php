{
  "name": "jcolombo/niftyquoter-api-php",
  "description": "PHP SDK for the NiftyQuoter sales proposal API",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/jcolombo/niftyquoter-api-php",
  "authors": [
    {
      "name": "Joel Colombo",
      "email": "jc-dev@360psg.com",
      "homepage": "https://360psg.com"
    }
  ],
  "support": {
    "issues": "https://github.com/jcolombo/niftyquoter-api-php/issues",
    "source": "https://github.com/jcolombo/niftyquoter-api-php"
  },
  "keywords": [
    "niftyquoter",
    "nifty quoter",
    "proposals",
    "sales proposals",
    "api",
    "sdk",
    "rest",
    "php"
  ],
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.8",
    "adbario/php-dot-notation": "^3.3"
  },
  "autoload": {
    "psr-4": {
      "Jcolombo\\NiftyquoterApiPhp\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Jcolombo\\NiftyquoterApiPhp\\Tests\\": "tests"
    }
  },
  "scripts": {
    "test": "./tests/validate",
    "test:dry-run": "./tests/validate --dry-run",
    "test:verbose": "./tests/validate --verbose"
  },
  "config": {
    "sort-packages": true
  }
}
